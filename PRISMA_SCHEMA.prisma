// Prisma Schema for Tender Compliance Validator
// Location: backend/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String
  lastName     String
  passwordHash String
  
  role         UserRole @default(PROCUREMENT_OFFICER)
  organizationId String
  
  /// Relations
  rfpsUploaded RFPDocument[]
  auditLogs    AuditLog[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  PROCUREMENT_OFFICER
  LEGAL_REVIEWER
  VIEWER
}

// ============================================================
// RFP DOCUMENT
// ============================================================

model RFPDocument {
  id              String   @id @default(cuid())
  title           String
  description     String?
  
  uploadedById    String
  uploadedBy      User     @relation(fields: [uploadedById], references: [id])
  uploadedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // File metadata
  fileUrl         String
  fileName        String
  fileFormat      FileFormat
  fileSizeBytes   Int
  documentHash    String   @unique  // For deduplication
  
  // Content
  extractedText   String   @db.Text
  summary         String?  @db.Text
  
  // Processing status
  status          RFPStatus @default(PENDING_PROCESSING)
  processingStartedAt DateTime?
  processingCompletedAt DateTime?
  errorMessage    String?
  
  isArchived      Boolean  @default(false)
  
  /// Relations
  requirements    Requirement[]
  proposals       VendorProposal[]
  auditLogs       AuditLog[]
  
  @@index([uploadedById])
  @@index([createdAt])
  @@index([status])
}

enum RFPStatus {
  PENDING_PROCESSING
  PROCESSED
  ERROR
}

enum FileFormat {
  PDF
  DOCX
  DOC
  TXT
  XLSX
}

// ============================================================
// REQUIREMENT
// ============================================================

model Requirement {
  id              String   @id @default(cuid())
  rfpDocumentId   String
  rfpDocument     RFPDocument @relation(fields: [rfpDocumentId], references: [id], onDelete: Cascade)
  
  // Content
  text            String   @db.Text
  summary         String?  @db.Text
  category        RequirementCategory
  priority        RequirementPriority
  isMandatory     Boolean
  
  // Keywords for matching
  keywords        String[] // JSON array
  
  // Evaluation
  acceptanceCriteria String? @db.Text
  weightingScore  Int?     @db.SmallInt
  
  // AI processing
  extractedByAI   Boolean  @default(true)
  manuallyEdited  Boolean  @default(false)
  aiConfidenceScore Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  /// Relations
  complianceResults ComplianceResult[]
  
  @@index([rfpDocumentId])
  @@index([category])
  @@index([isMandatory])
}

enum RequirementCategory {
  LEGAL
  COMMERCIAL
  TECHNICAL
  FINANCIAL
  TIMELINE
  COMPLIANCE
  OTHER
}

enum RequirementPriority {
  MANDATORY
  DESIRABLE
  OPTIONAL
}

// ============================================================
// VENDOR PROPOSAL
// ============================================================

model VendorProposal {
  id              String   @id @default(cuid())
  rfpDocumentId   String
  rfpDocument     RFPDocument @relation(fields: [rfpDocumentId], references: [id], onDelete: Cascade)
  
  // Vendor info
  vendorName      String
  vendorEmail     String?
  vendorContactPerson String?
  vendorPhone     String?
  vendorCompanyReg String?
  vendorWebsite   String?
  vendorCountry   String?
  
  // File info
  fileUrl         String
  fileName        String
  fileFormat      FileFormat
  fileSizeBytes   Int
  extractedText   String   @db.Text
  summary         String?  @db.Text
  
  // Processing
  status          ProposalStatus @default(PENDING_PROCESSING)
  processingStartedAt DateTime?
  processingCompletedAt DateTime?
  errorMessage    String?
  
  // Scoring
  overallComplianceScore Int?
  overallRiskLevel RiskSeverity?
  
  submittedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isArchived      Boolean  @default(false)
  
  /// Relations
  complianceResults ComplianceResult[]
  riskFlags       RiskFlag[]
  auditLogs       AuditLog[]
  
  @@index([rfpDocumentId])
  @@index([status])
  @@index([vendorName])
  @@index([createdAt])
}

enum ProposalStatus {
  PENDING_PROCESSING
  PROCESSED
  ERROR
}

// ============================================================
// COMPLIANCE RESULT
// ============================================================

model ComplianceResult {
  id              String   @id @default(cuid())
  requirementId   String
  requirement     Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  proposalId      String
  proposal        VendorProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  // Assessment
  status          ComplianceStatus
  complianceScore Int?     @db.SmallInt // 0-100
  evidenceText    String?  @db.Text
  
  // AI analysis
  analysisNotes   String?  @db.Text
  aiConfidenceScore Float?
  
  // Gaps
  gapDescription  String?  @db.Text
  deviationReason String?  @db.Text
  
  // Manual review
  reviewedBy      String?
  reviewNotes     String?  @db.Text
  isManuallyVerified Boolean @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  /// Relations
  riskFlags       RiskFlag[]
  
  @@unique([requirementId, proposalId])
  @@index([proposalId])
  @@index([status])
  @@index([complianceScore])
}

enum ComplianceStatus {
  COMPLIANT
  PARTIALLY_COMPLIANT
  NON_COMPLIANT
  UNCLEAR
  NOT_APPLICABLE
}

// ============================================================
// RISK FLAG
// ============================================================

model RiskFlag {
  id              String   @id @default(cuid())
  proposalId      String
  proposal        VendorProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  // Risk details
  title           String
  description     String   @db.Text
  category        RiskCategory
  severity        RiskSeverity
  
  // Context
  relatedRequirementId String?
  complianceResultId String?
  complianceResult ComplianceResult? @relation(fields: [complianceResultId], references: [id], onDelete: SetNull)
  evidenceText    String?  @db.Text
  sourceLocation  String?
  
  // Risk attributes
  isFinancialRisk Boolean  @default(false)
  isLegalRisk     Boolean  @default(false)
  isScheduleRisk  Boolean  @default(false)
  potentialImpact String?  @db.Text
  recommendedMitigation String? @db.Text
  
  // Tracking
  isRecognized    Boolean  @default(false)
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  resolutionStatus RiskResolutionStatus @default(OPEN)
  resolutionNotes String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([proposalId])
  @@index([severity])
  @@index([category])
  @@index([resolutionStatus])
}

enum RiskCategory {
  LEGAL
  FINANCIAL
  TIMELINE
  TECHNICAL
  VENDOR_CREDIBILITY
  OPERATIONAL
  REGULATORY
  CONTRACTUAL
}

enum RiskSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum RiskResolutionStatus {
  OPEN
  ACKNOWLEDGED
  MITIGATED
  RESOLVED
  ACCEPTED
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  action          String   // e.g., "UPLOAD_RFP", "VALIDATE_PROPOSAL"
  resourceType    String   // RFP, PROPOSAL, COMPLIANCE_RESULT
  resourceId      String
  
  changes         Json?    // JSON of what changed
  
  rfpDocumentId   String?
  rfpDocument     RFPDocument? @relation(fields: [rfpDocumentId], references: [id], onDelete: SetNull)
  
  proposalId      String?
  proposal        VendorProposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  
  timestamp       DateTime @default(now())
  
  @@index([userId])
  @@index([timestamp])
  @@index([resourceType])
  @@index([rfpDocumentId])
  @@index([proposalId])
}

// ============================================================
// PROCESSING QUEUE JOB
// ============================================================

model ProcessingJob {
  id              String   @id @default(cuid())
  type            JobType
  
  rfpDocumentId   String?
  proposalId      String?
  
  status          JobStatus @default(PENDING)
  progress        Int       @default(0) @db.SmallInt
  error           String?
  
  result          Json?     // Job result data
  
  createdAt       DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

enum JobType {
  EXTRACT_REQUIREMENTS
  VALIDATE_PROPOSAL
  PROCESS_FILE
  EXTRACT_TEXT
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

/* 
INDEXES SUMMARY:
- RFPDocument: uploadedById, createdAt, status
- VendorProposal: rfpDocumentId, status, vendorName, createdAt  
- Requirement: rfpDocumentId, category, isMandatory
- ComplianceResult: (requirementId, proposalId) UNIQUE, proposalId, status, complianceScore
- RiskFlag: proposalId, severity, category, resolutionStatus
- AuditLog: userId, timestamp, resourceType, rfpDocumentId, proposalId
- ProcessingJob: status, type, createdAt

FOREIGN KEYS:
- VendorProposal.rfpDocumentId → RFPDocument (CASCADE)
- Requirement.rfpDocumentId → RFPDocument (CASCADE)
- ComplianceResult.requirementId → Requirement (CASCADE)
- ComplianceResult.proposalId → VendorProposal (CASCADE)
- RiskFlag.proposalId → VendorProposal (CASCADE)
- RiskFlag.complianceResultId → ComplianceResult (SET NULL)
- AuditLog has multiple optional FKs to track changes across resources
*/
