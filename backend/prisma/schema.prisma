// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  projects  Project[]
  proposals VendorProposal[]

  @@index([email])
}

model Project {
  id        String     @id @default(cuid())
  name      String
  description String?
  status    String     @default("draft") // draft, active, completed
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  documents RFPDocument[]
  requirements ExtractedRequirement[]
  proposals VendorProposal[]

  @@index([userId])
  @@index([status])
}

model RFPDocument {
  id        String     @id @default(cuid())
  filename  String
  fileSize  Int
  uploadedAt DateTime   @default(now())
  extractedText String?
  pageCount Int?

  // Relations
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  requirements ExtractedRequirement[]

  @@index([projectId])
}

model ExtractedRequirement {
  id        String     @id @default(cuid())
  text      String
  category  String?
  priority  String     @default("medium") // high, medium, low
  order     Int        @default(0)

  // Relations
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  documentId String
  document   RFPDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  complianceResults ComplianceResult[]

  @@index([projectId])
  @@index([documentId])
}

model VendorProposal {
  id        String     @id @default(cuid())
  vendorName String
  filename   String
  fileSize   Int
  uploadedAt DateTime   @default(now())
  proposalText String?
  matchingCriteria Json?
  requirementsSnapshot Json?
  
  // Validation metadata
  overallScore Int? // 0-100
  metCount   Int?
  partialCount Int?
  missingCount Int?
  validatedAt DateTime?
  
  // Relations
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  complianceResults ComplianceResult[]

  @@index([projectId])
  @@index([userId])
  @@index([vendorName])
}

model ComplianceResult {
  id        String     @id @default(cuid())
  status    String     // "Met", "Partially Met", "Missing"
  confidence Int       // 0-100
  matchedExcerpt String?
  explanation String?
  suggestedFollowUp String?
  flaggedForReview Boolean @default(false)
  notes     String?
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  proposalId String
  proposal   VendorProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  requirementId String
  requirement ExtractedRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([proposalId, requirementId])
  @@index([proposalId])
  @@index([requirementId])
}

model ValidationCache {
  id        String     @id @default(cuid())
  proposalHash String   @unique
  requirementIds String  // JSON array of requirement IDs
  result    String     // JSON string of validation result
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([expiresAt])
}
